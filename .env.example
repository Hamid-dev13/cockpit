# Copie ce fichier en .env.local et renseigne ta clé Mistral.
# Cette clé est lue UNIQUEMENT côté serveur (route /api/ai) — jamais exposée au navigateur.
MISTRAL_API_KEY=

# Optionnel : modèle utilisé (defaut: mistral-small-latest).
# Pour des réponses plus fines: mistral-large-latest
# MISTRAL_MODEL=mistral-small-latest
