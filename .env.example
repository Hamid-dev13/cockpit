# Variables d'environnement. En local :
#  - DATABASE_URL va dans .env (lu par le CLI Prisma ET par l'app)
#  - les secrets vont dans .env.local
# En production (Coolify), tout est defini dans le panneau de variables.

# --- Base de donnees Postgres (fichier .env) ---
# En local : "make up" lance un Postgres inclus, ou pointe vers ton propre Postgres.
# En prod : fourni par la base Postgres managee de Coolify.
DATABASE_URL="postgresql://cockpit:cockpit@localhost:5433/cockpit?schema=public"

# --- Secrets (fichier .env.local) ---

# Cle API Mistral, lue uniquement cote serveur (route /api/ai).
MISTRAL_API_KEY=

# Optionnel : modele utilise (defaut: mistral-small-latest).
# MISTRAL_MODEL=mistral-large-latest

# Secret de signature des JWT (access + refresh tokens).
# Genere une valeur forte : openssl rand -hex 32
AUTH_SECRET=

# Inscriptions : fermees par defaut. Mettre "true" pour autoriser la creation de comptes.
# ALLOW_REGISTRATION=true
