generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Candidature {
  id        Int       @id @default(autoincrement())
  company   String
  role      String    @default("Poste")
  status    String    @default("wishlist")
  kind      String    @default("offer") // offer | spontaneous | network
  channel   String    @default("email") // email | phone | form | linkedin | other
  salary    String    @default("—")
  stack     String    @default("") // CSV: SQLite n'a pas de type tableau
  location  String    @default("—")
  url       String    @default("")
  description String  @default("")
  last      DateTime  @default(now())
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id            Int         @id @default(autoincrement())
  txt           String
  createdAt     DateTime    @default(now())
  candidature   Candidature @relation(fields: [candidatureId], references: [id], onDelete: Cascade)
  candidatureId Int
}
