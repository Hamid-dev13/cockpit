generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidature {
  id        Int       @id @default(autoincrement())
  company   String
  role      String    @default("Poste")
  status    String    @default("wishlist")
  kind      String    @default("offer") // offer | spontaneous | network
  channel   String    @default("email") // email | phone | form | linkedin | other
  salary    String    @default("—")
  stack     String    @default("") // liste de technos stockee en CSV
  location  String    @default("—")
  contract  String    @default("—") // CDI, CDD, Freelance, Stage, Alternance…
  remote    String    @default("—") // Remote, Hybride, Sur site
  seniority String    @default("—") // Junior, Confirme, Senior…
  companyInfo String  @default("") // secteur / taille / activite de l'entreprise
  url       String    @default("")
  description String  @default("")
  last      DateTime  @default(now())
  createdAt DateTime  @default(now())
  comments  Comment[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  firstName     String
  lastName      String
  passwordHash  String
  createdAt     DateTime       @default(now())
  candidatures  Candidature[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Comment {
  id            Int         @id @default(autoincrement())
  txt           String
  createdAt     DateTime    @default(now())
  candidature   Candidature @relation(fields: [candidatureId], references: [id], onDelete: Cascade)
  candidatureId Int
}
